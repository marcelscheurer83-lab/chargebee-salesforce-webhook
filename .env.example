# Chargebee (from Settings > API Keys in Chargebee)
CHARGEBEE_SITE=your-site
CHARGEBEE_API_KEY=your_api_key

# Google Sheets - use one of these approaches:
# Option A: Service account JSON path (recommended for automation)
GOOGLE_CREDENTIALS_PATH=path/to/service-account.json

# Option B: Or set the sheet ID after sharing it with the service account email
GOOGLE_SHEET_ID=your_google_sheet_id

# Optional: Sheet tab/sheet name (default: "Chargebee Add-Ons")
GOOGLE_SHEET_TAB=Chargebee Add-Ons

# Optional: comma-separated exact item_price_ids only (overrides prefix matching in chargebee_client.py)
# CHARGEBEE_ADDON_IDS=id-one,id-two

# --- Webhook service (deploy with Dockerfile; set these in the host’s env UI — no local run needed)
# --- Chargebee HTTP Basic auth for POST /chargebee
# WEBHOOK_BASIC_USER=chargebee
# WEBHOOK_BASIC_PASS=long-random-secret
# Optional: path to JSON state file (subscription line quantities + processed event ids)
# WEBHOOK_STATE_PATH=./webhook_state.json
# Optional: POST /admin/seed-state with header X-Seed-Secret (merge baselines from Chargebee API)
# WEBHOOK_SEED_SECRET=long-random-secret

# Salesforce API user (Integration user recommended). Domain: login | test
# SF_USERNAME=integration@example.com
# SF_PASSWORD=your_password
# SF_SECURITY_TOKEN=your_token
# SF_DOMAIN=login

# Map Chargebee customer → Salesforce Account (use one approach):
# A) Customer custom field API name in webhook JSON (e.g. cf_salesforce_account_id)
# CHARGEBEE_CUSTOMER_SF_ACCOUNT_FIELD=cf_salesforce_account_id
# B) Or Account field that stores Chargebee customer id (e.g. Chargebee_Customer_Id__c)
# SF_ACCOUNT_CHARGEBEE_CUSTOMER_FIELD=Chargebee_Customer_Id__c

# Opportunity defaults (adjust to your org’s required Stage names)
# SF_OPPORTUNITY_STAGE=Prospecting
# SF_OPPORTUNITY_CLOSE_DAYS=30
# SF_OPPORTUNITY_NAME_TEMPLATE=Expansion: {company} (+{delta} CRM self-serve seats)
# SF_OPPORTUNITY_RECORD_TYPE_ID=

# Opportunity Products (standard price book). One line item per Chargebee add-on line in the event.
# Default product name if unset: Additional CRM Seats
# SF_PRODUCT_NAME=Additional CRM Seats
# Or: SF_PRODUCT2_ID=01t...  (Product2 Id — avoids name mismatches)
# Or: SF_PRICEBOOK_ENTRY_ID=01u...  (PricebookEntry Id — if not using standard book, use the entry you need)

# Baselines: run `python seed_webhook_state.py` with CHARGEBEE_* set so the first webhook isn’t a silent baseline.
# On Railway: `railway run python seed_webhook_state.py` (use same volume / WEBHOOK_STATE_PATH as the web service if state is persisted)

# --- Expansion Opportunity dates / MRR (API names from Setup → Object Manager → Opportunity / Line Item)
# Close Date defaults to Chargebee event date (UTC). Set SF_OPPORTUNITY_CLOSE_DATE_USE_EVENT=0 to use SF_OPPORTUNITY_CLOSE_DAYS instead.
# SF_OPPORTUNITY_CLOSE_DATE_USE_EVENT=1
# If Salesforce rejects date fields, try DateTime values: SF_OPP_DATE_FIELDS_USE_DATETIME=1
# MRR defaults to Opportunity.update AFTER products (not on create). To put MRR on create instead: SF_OPP_MRR_SET_ON_CREATE=1
# SF_OPP_CONTRACT_START_DATE_FIELD=Contract_Start_Date__c
# SF_OPP_CONTRACT_END_DATE_FIELD=Contract_End_Date__c
# Integration user needs Edit (FLS) on every mapped Opportunity field; if a field is read-only, create retries without it.
# SF_OPP_TERM_MONTHS_FIELD=Term_Months__c
# SF_OPP_MRR_FIELD=MRR__c
# Open Renewal on Account (same API names you use on Opportunity). End date field must be a Date on the Renewal opp.
# SF_RENEWAL_RECORD_TYPE_DEVELOPER_NAME=Renewal
# SF_RENEWAL_CONTRACT_END_DATE_FIELD=Contract_End_Date__c
# OpportunityLineItem custom dates / term (optional; same values as Opportunity)
# SF_OLI_START_DATE_FIELD=Start_Date__c
# SF_OLI_END_DATE_FIELD=End_Date__c
# SF_OLI_TERM_MONTHS_FIELD=Term_Months__c
# Product quantity: delta = seats added this event (new minus last stored); total = Chargebee line quantity after change
# SF_OLI_QUANTITY_MODE=delta
# Note: Opportunity Amount and MRR still use (unit price × seat delta). Only OLI Quantity switches with total.
