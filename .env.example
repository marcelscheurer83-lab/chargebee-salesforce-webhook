# Chargebee (from Settings > API Keys in Chargebee)
CHARGEBEE_SITE=your-site
CHARGEBEE_API_KEY=your_api_key

# Google Sheets - use one of these approaches:
# Option A: Service account JSON path (recommended for automation)
GOOGLE_CREDENTIALS_PATH=path/to/service-account.json

# Option B: Or set the sheet ID after sharing it with the service account email
GOOGLE_SHEET_ID=your_google_sheet_id

# Optional: Sheet tab/sheet name (default: "Chargebee Add-Ons")
GOOGLE_SHEET_TAB=Chargebee Add-Ons

# Optional: comma-separated exact item_price_ids only (overrides prefix matching in chargebee_client.py)
# CHARGEBEE_ADDON_IDS=id-one,id-two

# --- Webhook service (deploy with Dockerfile; set these in the host’s env UI — no local run needed)
# --- Chargebee HTTP Basic auth for POST /chargebee
# WEBHOOK_BASIC_USER=chargebee
# WEBHOOK_BASIC_PASS=long-random-secret
# Optional: path to JSON state file (subscription line quantities + processed event ids)
# WEBHOOK_STATE_PATH=./webhook_state.json
# After each successful webhook, merge all active self-serve line qtys from Chargebee API into state (default on). Set 0 to skip extra API calls.
# WEBHOOK_MERGE_CHARGEBEE_STATE_ON_WEBHOOK=1
# Optional: POST /admin/seed-state with header X-Seed-Secret (merge baselines from Chargebee API)
# WEBHOOK_SEED_SECRET=long-random-secret
# For local script: python seed_webhook_state.py --remote (same secret; public URL of deployed app)
# WEBHOOK_PUBLIC_URL=https://your-service.up.railway.app

# --- Salesforce settings bundle (optional — avoids dozens of Railway variables)
# • Copy salesforce_field_map.example.json → salesforce_field_map.json in the app directory (gitignored), or
# • One host var: SF_CONFIG_JSON with a JSON object of {"SF_OPP_MRR_FIELD":"MRR__c", ...}, or
# • SF_CONFIG_PATH=/absolute/path/to/map.json
# Keys are the same as the SF_* names below. Host env ALWAYS overrides a key if both are set.
# Keep SF_PASSWORD / CHARGEBEE_API_KEY / tokens in Railway only (do not commit the map with secrets).

# Salesforce API user (Integration user recommended). Domain: login | test
# SF_USERNAME=integration@example.com
# SF_PASSWORD=your_password
# SF_SECURITY_TOKEN=your_token
# SF_DOMAIN=login

# Map Chargebee customer → Salesforce Account (use one approach):
# A) Customer custom field API name in webhook JSON (e.g. cf_salesforce_account_id)
# CHARGEBEE_CUSTOMER_SF_ACCOUNT_FIELD=cf_salesforce_account_id
# B) Or Account field that stores Chargebee customer id (e.g. Chargebee_Customer_Id__c)
# SF_ACCOUNT_CHARGEBEE_CUSTOMER_FIELD=Chargebee_Customer_Id__c

# Opportunity defaults (adjust to your org’s required Stage names)
# SF_OPPORTUNITY_STAGE=Prospecting
# SF_OPPORTUNITY_CLOSE_DAYS=30
# SF_OPPORTUNITY_NAME_TEMPLATE=Expansion: {company} (+{delta} CRM self-serve seats)
# SF_OPPORTUNITY_RECORD_TYPE_ID=

# Product / Quote (standard Salesforce Quotes must be enabled). Each expansion opp gets one Quote;
# QuoteLineItem quantity = seat delta for that webhook. Resolve product via ONE of:
# SF_PRODUCT_NAME=Additional CRM Seats
# SF_PRODUCT2_ID=01t...
# SF_PRICEBOOK_ENTRY_ID=01u...
# SF_QUOTE_NAME_TEMPLATE=Expansion quote: {company} (+{delta} CRM self-serve seats)
# SF_QUOTE_STATUS=Draft
# SF_QUOTE_CONTACT_ID=003...  (optional; required in some orgs)
# SF_QUOTE_EXPIRATION_DAYS=30
# If Quote header date fields are unset, reuse SF_OLI_* API names on the Quote (same field on both objects)
# SF_QUOTE_HEADER_MIRROR_LINE_DATE_FIELDS=1
# Quote header custom fields (API names from your org). MRR/ARR = delta seat revenue (monthly / ×12).
# SF_QUOTE_CONTRACT_START_DATE_FIELD=Contract_Start_Date__c
# SF_QUOTE_CONTRACT_END_DATE_FIELD=Contract_End_Date__c
# SF_QUOTE_TERM_MONTHS_FIELD=Term_Months__c
# SF_QUOTE_AUTORENEW_FIELD=Auto_Renew__c
# Picklist: use the string Yes or No (not a JSON boolean). In SF_CONFIG_JSON use "Yes" — bare true becomes the string "true" and breaks picklists.
# Checkbox field: SF_QUOTE_AUTORENEW_AS_BOOLEAN=1 and SF_QUOTE_AUTORENEW_VALUE=true or false.
# SF_QUOTE_AUTORENEW_VALUE=Yes
# SF_QUOTE_AUTORENEW_AS_BOOLEAN=0
# SF_QUOTE_MRR_FIELD=Total_MRR__c
# SF_QUOTE_ARR_FIELD=Total_ARR__c
# The API user must have Edit field-level security on these Quote fields (Permission Set → Quote → Field Permissions).
# Optional: currency field on Quote for one-time total — webhook sets it to 0 after lines. Use the writable source field
# (e.g. One_Time_Fees__c), not a formula field such as One_Time_Fees_Template__c (IF(source=0,NULL,source) shows blank when 0).
# SF_QUOTE_ONETIME_FEES_FIELD=One_Time_Fees__c
# Optional: extra QuoteLineItem fields as JSON (recurring vs one-time picklists, Revenue Cloud charge type, etc.).
# SF_QUOTELINEITEM_STATIC_FIELDS_JSON={"Your_Charge_Type__c":"Recurring"}
# After line items: sync standard Quote to Opportunity (standard Quote.IsSyncing). Set to 0 to skip.
# SF_QUOTE_SYNC_TO_OPPORTUNITY=1
# If IsSyncing is not used, optional custom checkbox API name + value:
# SF_QUOTE_SYNCING_FIELD=Syncing__c
# SF_QUOTE_SYNCING_VALUE=true
# QuoteLineItem MRR/ARR per line (unit price × seat delta, monthly / ×12)
# SF_QTI_MRR_FIELD=MRR__c
# SF_QTI_ARR_FIELD=ARR__c

# Baselines: empty state + first webhook still uses delta vs 0 (risky after deploy). Seed once before go-live or use a persistent volume for WEBHOOK_STATE_PATH.
# After each successful webhook: payload sync + (by default) full Chargebee merge into state; manual seed remains available.

# --- Expansion Opportunity dates / MRR (API names from Setup → Object Manager → Opportunity / Line Item)
# Event date → Opportunity Close Date and contract start use this IANA timezone (default Eastern / Miami).
# SF_EVENT_TIMEZONE=America/New_York
# Close Date defaults to that local calendar date from occurred_at. Set SF_OPPORTUNITY_CLOSE_DATE_USE_EVENT=0 to use SF_OPPORTUNITY_CLOSE_DAYS instead.
# SF_OPPORTUNITY_CLOSE_DATE_USE_EVENT=1
# If Salesforce rejects date fields, try DateTime values: SF_OPP_DATE_FIELDS_USE_DATETIME=1
# MRR defaults to Opportunity.update AFTER products (not on create). To put MRR on create instead: SF_OPP_MRR_SET_ON_CREATE=1
# SF_OPP_CONTRACT_START_DATE_FIELD=Contract_Start_Date__c
# SF_OPP_CONTRACT_END_DATE_FIELD=Contract_End_Date__c
# Integration user needs Edit (FLS) on every mapped Opportunity field; if a field is read-only, create retries without it.
# SF_OPP_TERM_MONTHS_FIELD=Term_Months__c
# SF_OPP_MRR_FIELD=MRR__c
# Optional: separate “expansion / delta” MRR field on the Opportunity (same numeric value as seat-delta MRR)
# SF_OPP_EXPANSION_MRR_FIELD=Expansion_MRR__c
# Open Renewal on Account (same API names you use on Opportunity). Dates must be Date fields on the Renewal opp.
# SF_RENEWAL_RECORD_TYPE_DEVELOPER_NAME=Renewal
# Expansion opp contract end = (Renewal contract start) minus 1 day (preferred)
# SF_RENEWAL_CONTRACT_START_DATE_FIELD=Contract_Start_Date__c
# Legacy only if SF_RENEWAL_CONTRACT_START_DATE_FIELD is unset (otherwise you can omit this variable):
# SF_RENEWAL_CONTRACT_END_DATE_FIELD=Contract_End_Date__c
# Optional QuoteLineItem custom dates / term (env prefix SF_OLI_* for historical reasons)
# SF_OLI_START_DATE_FIELD=Start_Date__c
# SF_OLI_END_DATE_FIELD=End_Date__c
# SF_OLI_TERM_MONTHS_FIELD=Term_Months__c
# Opportunity Amount and mapped MRR fields use (unit price × seat delta).
