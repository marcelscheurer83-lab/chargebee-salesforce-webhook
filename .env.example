# Chargebee (from Settings > API Keys in Chargebee)
CHARGEBEE_SITE=your-site
CHARGEBEE_API_KEY=your_api_key

# Google Sheets - use one of these approaches:
# Option A: Service account JSON path (recommended for automation)
GOOGLE_CREDENTIALS_PATH=path/to/service-account.json

# Option B: Or set the sheet ID after sharing it with the service account email
GOOGLE_SHEET_ID=your_google_sheet_id

# Optional: Sheet tab/sheet name (default: "Chargebee Add-Ons")
GOOGLE_SHEET_TAB=Chargebee Add-Ons
